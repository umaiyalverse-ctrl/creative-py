def main():
    print()
    slow_print("=" * 55)
    slow_print("   🚀 Welcome to N.O.V.A — Space Mission Planner 🚀")
    slow_print("   Navigation & Orbital Voyage Assistant")
    slow_print("=" * 55)
    print()
    name = input("   Enter your astronaut name: ").strip()
    if name == "":
        name = "Astronaut"
    print()
    slow_print(f"   Welcome aboard, Commander {name}! 🌌")
    print()
    while True:
        try:
            weight = float(input("   Enter your weight on Earth (in kg): "))
            if weight <= 0:
                print("   Please enter a valid weight!")
                continue
            break
        except ValueError:
            print("   Please enter a number!")
    print()
    slow_print("   Available destinations:")
    print()
    for planet in planets:
        print(f"   🪐 {planet.capitalize()}")
    print()
    while True:
        destination = input("   Where do you want to go? ").strip().lower()
        if destination in planets:
            break
        else:
            print(f"   '{destination}' not found! Please choose from the list above.")
    data = planets[destination]
    if destination == "uplanet":
        uplanet_reveal()
    print()
    slow_print("   ⏳ Generating your mission briefing...", 0.02)
    time.sleep(1)
    print()
    slow_print("=" * 55)
    slow_print(f"   🛸 MISSION BRIEFING — DESTINATION: {destination.upper()}")
    slow_print("=" * 55)
    print()
    slow_print(f"   👨‍🚀 Commander     : {name}")
    time.sleep(0.3)
    slow_print(f"   🌍 Departing     : Earth")
    time.sleep(0.3)
    slow_print(f"   🪐 Destination   : {destination.capitalize()}")
    time.sleep(0.3)
    slow_print(f"   📅 Travel Time   : {data['travel_days']} days ({round(data['travel_days']/365, 1)} years)")
    time.sleep(0.3)
    slow_print(f"   🌡️  Temperature   : {data['temp_c']}°C")
    time.sleep(0.3)
    slow_print(f"   ⚖️  Your weight   : {calculate_weight(weight, data['gravity'])} kg on {destination.capitalize()}")
    time.sleep(0.3)
    slow_print(f"   🧬 Survival      : {survival_badge(data['survival'])}")
    time.sleep(0.3)
    print()
    slow_print(f"   📡 NOVA SAYS: {data['fact']}")
    print()
    slow_print("=" * 55)
    print()
    slow_print(f"   Safe travels, Commander {name}! 🌠")
    slow_print("   The universe is waiting for you.")
    slow_print("=" * 55)
    print()
    again = input("   Plan another mission? (yes / no): ").strip().lower()
    if again == "yes":
        main()
    else:
        print()
        slow_print("   🚀 Mission Control signing off. Goodbye, Commander!")
        print()

main()
