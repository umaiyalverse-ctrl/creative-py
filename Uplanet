def slow_print(text, delay=0.03):
    for char in text:
        print(char, end='', flush=True)
        time.sleep(delay)
    print()

def calculate_weight(earth_weight, gravity_factor):
    return round(earth_weight * gravity_factor, 2)

def survival_badge(status):
    if status == "IMPOSSIBLE":
        return "💀 IMPOSSIBLE — Humans cannot survive here."
    elif status == "DANGER":
        return "⚠️  HIGH DANGER — Extreme conditions. Mission risky."
    elif status == "PERFECT":
        return "🌟 PERFECT — Uplanet was literally made for humans!"
    else:
        return "✅ POSSIBLE — With the right gear, you can survive!"

